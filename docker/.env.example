# ============================================================
# OpenClaw — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Azure AI Foundry (OpenAI-compatible) ─────────────────────
# Your Azure OpenAI resource endpoint
AZURE_API_BASE=https://YOUR-RESOURCE-NAME.openai.azure.com

# Azure OpenAI API key (from Azure Portal > AI Foundry > Keys)
AZURE_API_KEY=your-azure-openai-api-key

# API version — use the latest stable
AZURE_API_VERSION=2024-02-01

# Your GPT-4o deployment name (as named in Azure AI Foundry)
AZURE_DEPLOYMENT_NAME=gpt-4o

# ── OpenClaw Model Config ────────────────────────────────────
# Format: azure/<your-deployment-name>
OPENCLAW_MODEL=azure/gpt-4o

# ── Messaging Channels (add only what you use) ───────────────

# Telegram: Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeffGGhhIIjjKKllMMnnOOppQQrr

# Discord: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# ── Gateway Settings ──────────────────────────────────────────
# Bind to loopback only — access via SSH tunnel (recommended)
OPENCLAW_GATEWAY_BIND=loopback

# Set to 1 to enable agent sandboxing (more secure)
OPENCLAW_SANDBOX=1

# Persist config and workspace outside container
OPENCLAW_CONFIG_DIR=/home/azureuser/.openclaw/config
OPENCLAW_WORKSPACE_DIR=/home/azureuser/.openclaw/workspace
