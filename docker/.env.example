# ============================================================
# OpenClaw — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Azure AI (OpenAI-compatible) ──────────────────────────────
# Standard Azure OpenAI endpoint (recommended):
#   https://<your-resource>.openai.azure.com/openai/v1
#
# Azure AI Foundry endpoint (project-based, if applicable):
#   https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
#
# Use whichever matches the "Target URI" shown in Azure Portal.
AZURE_API_BASE=https://<your-resource>.openai.azure.com/openai/v1

# Azure OpenAI API key (from Azure Portal > your resource > Keys and Endpoint)
AZURE_API_KEY=your-azure-api-key-here

# Your model deployment name exactly as set in Azure AI Foundry
# Examples: gpt-4o, gpt-4.1, or any custom name you gave it
AZURE_DEPLOYMENT_NAME=your-deployment-name

# ── Messaging Channels (add only what you use) ───────────────

# Telegram: Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeffGGhhIIjjKKllMMnnOOppQQrr

# Discord: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# ── Gateway Settings ──────────────────────────────────────────
# Set to 1 to enable agent sandboxing (more secure)
OPENCLAW_SANDBOX=1

# Persist the agent workspace outside the container.
# Replace <admin-username> with the username you chose during deploy (default: azureuser)
OPENCLAW_WORKSPACE_DIR=/home/<admin-username>/.openclaw/workspace

# NOTE: OPENCLAW_CONFIG_DIR is intentionally omitted.
# configure-openclaw.sh writes the model config directly to
# ~/.openclaw/openclaw.json on the VM, bypassing this variable.
# This avoids a Docker Compose env var precedence issue where the shell
# environment can override the value set here, causing config to be
# read from the wrong path.
